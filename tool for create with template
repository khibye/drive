"""
Meeting Summary Tool
Requirements: docxtpl, boto3
"""

import logging
import os
import tempfile

from docxtpl import DocxTemplate
from fastapi import UploadFile
from pydantic import BaseModel

from open_webui.models.users import Users
from open_webui.routers.files import upload_file_handler as owui_upload_file

log = logging.getLogger(__name__)

TEMPLATE_PATH = "./data/resources/meeting-template.docx"


class Tools:
    class Valves(BaseModel):
        open_webui_url: str = "http://localhost:8080/"

    def __init__(self):
        self.valves = self.Valves()

    def _get_template_path(self) -> tuple[str, bool]:
        s3_endpoint_url = os.environ.get("S3_ENDPOINT_URL")
        s3_bucket_name = os.environ.get("S3_BUCKET_NAME")

        if s3_endpoint_url and s3_bucket_name:
            import boto3

            key = TEMPLATE_PATH.lstrip("/")

            session_kwargs = {}
            aws_access_key_id = os.environ.get("AWS_ACCESS_KEY_ID")
            aws_secret_access_key = os.environ.get("AWS_SECRET_ACCESS_KEY")
            if aws_access_key_id and aws_secret_access_key:
                session_kwargs["aws_access_key_id"] = aws_access_key_id
                session_kwargs["aws_secret_access_key"] = aws_secret_access_key

            s3_client = boto3.Session(**session_kwargs).client("s3", endpoint_url=s3_endpoint_url)
            tmp = tempfile.NamedTemporaryFile(suffix=".docx", delete=False)
            try:
                s3_client.download_fileobj(s3_bucket_name, key, tmp)
                tmp.flush()
                return tmp.name, True
            except Exception as e:
                raise Exception(f"Failed to download template from S3: {e}")
            finally:
                tmp.close()

        return TEMPLATE_PATH, False

    async def create_meeting_summary(
        self,
        __user__: dict,
        meeting_subject: str,
        meeting_goal: str,
        meeting_date: str,
        meeting_leader_name: str,
        meeting_leader_title: str,
        participants: str,
        discussion_points: str,
        action_items: str,
        leader_closing: str,
        summarizer_title: str,
        issuing_body: str,
    ) -> dict[str, str]:
        """
        Creates a formatted meeting summary Word document.
        Call this tool after confirming all meeting details with the user.

        Parameters — provide exactly as described:

        meeting_subject: The meeting topic. Example: "פיתוח מערכת סיכום אוטומטי"

        meeting_goal: The purpose or objective of the meeting, inferred from the transcript.
        What the participants aimed to achieve, decide, or align on.
        Example: "קבלת החלטות על בחירת מודל והגדרת משימות לשבוע הקרוב"

        meeting_date: Date in DD/MM/YYYY format. Example: "15/03/2024"

        meeting_leader_name: Full name of meeting leader. Example: "שירה כהן"

        meeting_leader_title: Job title of meeting leader. Example: "מנכ״לית"

        participants: One participant per line, format "name|title|department".
        Use empty string for unknown department.
        Example:
        "שירה כהן|מנכ״לית|הנהלה
        מיכל לוי|רפרנטית טכנולוגית|
        חני גל|מתכנתת|"

        discussion_points: One point per line, each starting with "- ".
        Use the required Hebrew vocabulary naturally within each point.
        Example:
        "- במסגרת הדיון הוצגה היכולת להפיק סיכומים אוטומטיים
        - עלה כי יש צורך לבחור מודל בסיס בעברית
        - הודגש כי יש לבדוק אפשרות התנסות לפני פריסה עצמאית"

        action_items: One task per line in format "task|owner|deadline".
        Use "לא הוגדר" for unknown owner or deadline.
        Do NOT convert relative dates — keep היום, מחר, בשבוע הבא as-is.
        Example:
        "בדיקת פריסת מודל|מיכל|היום
        הכנת system prompt|חני|מחר
        קיום פגישת המשך|לא הוגדר|בעוד שבוע"

        leader_closing: One point per line, each starting with "- ".
        Use the required Hebrew vocabulary naturally within each point.
        Example:
        "- מוביל הדיון ציין כי נעשתה עבודה יפה מאוד
        - נדרש לטפל בנושא אבטחת מידע כתנאי לביצוע
        - מומלץ לבצע הדגמה של חמישה תוצרים עד מחר"

        summarizer_title: Job title of the person writing the summary.
        Example: "מנהלת לשכה"

        issuing_body: The department or organization issuing this summary.
        Example: "מחלקת הנהלה"
        """

        # Parse participants: "name|title|department" per line
        participants_list = []
        for line in participants.strip().splitlines():
            line = line.strip()
            if not line:
                continue
            parts = line.split("|")
            participants_list.append({
                "name": parts[0].strip() if len(parts) > 0 else "",
                "title": parts[1].strip() if len(parts) > 1 else "[תפקיד לא צוין]",
                "department": parts[2].strip() if len(parts) > 2 else "",
            })

        # Group participants by department (preserving insertion order)
        participants_by_dept = {}
        no_dept = []
        for p in participants_list:
            dept = p["department"]
            if dept:
                if dept not in participants_by_dept:
                    participants_by_dept[dept] = []
                participants_by_dept[dept].append({"name": p["name"], "title": p["title"]})
            else:
                no_dept.append({"name": p["name"], "title": p["title"]})

        # Parse discussion points: one per line starting with "- "
        discussion_list = []
        for line in discussion_points.strip().splitlines():
            line = line.strip().lstrip("- ").strip()
            if line:
                discussion_list.append(line)

        # Parse action items: "task|owner|deadline" per line
        action_list = []
        for line in action_items.strip().splitlines():
            line = line.strip()
            if not line:
                continue
            parts = line.split("|")
            action_list.append({
                "task": parts[0].strip() if len(parts) > 0 else "",
                "owner": parts[1].strip() if len(parts) > 1 else "לא הוגדר",
                "deadline": parts[2].strip() if len(parts) > 2 else "לא הוגדר",
            })

        # Parse leader closing: one per line starting with "- "
        closing_list = []
        for line in leader_closing.strip().splitlines():
            line = line.strip().lstrip("- ").strip()
            if line:
                closing_list.append(line)

        context = {
            "meeting_subject": meeting_subject,
            "meeting_goal": meeting_goal,
            "meeting_date": meeting_date,
            "leader_name": meeting_leader_name,
            "leader_title": meeting_leader_title,
            "participants": participants_list,
            "participants_by_dept": participants_by_dept,
            "participants_no_dept": no_dept,
            "discussion_points": discussion_list,
            "action_items": action_list,
            "leader_closing": closing_list,
            "summarizer_title": summarizer_title,
            "issuing_body": issuing_body,
        }

        template_path, is_temp = self._get_template_path()
        try:
            doc = DocxTemplate(template_path)
            doc.render(context)
        except Exception as e:
            raise Exception(f"Failed to render template: {str(e)}")
        finally:
            if is_temp:
                try:
                    os.unlink(template_path)
                except OSError:
                    pass

        filename = f"סיכום_דיון_{meeting_subject[:30]}.docx"

        with tempfile.NamedTemporaryFile(suffix=".docx", delete=True) as temp_file:
            temp_path = temp_file.name
            doc.save(temp_path)

            user_id = __user__.get("id")
            if user_id is None:
                raise Exception(f"No user ID available: {__user__}")

            user_obj = Users.get_user_by_id(user_id)
            if not user_obj:
                raise Exception(f"User not found with ID: {user_id}")

            content_type = "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
            metadata = {"description": f"סיכום דיון — {meeting_subject}"}

            try:
                file_url = _upload_file(
                    user=user_obj,
                    filename=filename,
                    file_path=temp_path,
                    content_type=content_type,
                    metadata=metadata,
                    base_url=self.valves.open_webui_url,
                )
            except Exception as e:
                log.error(f"Failed to upload meeting summary: {str(e)}")
                raise Exception(f"Failed to upload meeting summary: {str(e)}")

            return {"file_url": file_url, "filename": filename}


class _MockRequest:
    def __init__(self) -> None:
        from types import SimpleNamespace
        self.app = SimpleNamespace()
        self.app.state = SimpleNamespace()
        self.app.state.config = SimpleNamespace()
        self.app.state.config.ALLOWED_FILE_EXTENSIONS = None
        self.app.state.config.STT_SUPPORTED_CONTENT_TYPES = None
        self.app.state.config.CONTENT_EXTRACTION_ENGINE = None


def _upload_file(user, filename, file_path, content_type, metadata, base_url):
    with open(file_path, "rb") as file_content:
        upload_file_obj = UploadFile(filename=filename, file=file_content)
        upload_file_obj.headers = {"content-type": content_type}
        request_obj = _MockRequest()
        file_response = owui_upload_file(
            request=request_obj,
            file=upload_file_obj,
            metadata=metadata,
            process=False,
            user=user,
        )
    file_id = file_response.id
    return f"{base_url.strip('/')}/api/v1/files/{file_id}/content"
